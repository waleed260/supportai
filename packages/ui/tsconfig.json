{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types"]
  },
  "include": ["src", "nativewind-env.d.ts"]
}
